# ===================================================================
# website/.env.example
# Personal/marketing website — template for website/.env.local
# Copy to .env.local and fill in real values before running
# Safe to commit — contains no real credentials
# ===================================================================

# Stripe (payment processing)
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Get from https://dashboard.stripe.com/webhooks after creating a webhook endpoint
# Endpoint URL: https://aetherisvision.com/api/webhooks/stripe
# Events: invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET="whsec_..."

# Blog subscription provider endpoint (optional)
NEXT_PUBLIC_BLOG_SUBSCRIBE_URL="https://your-provider-endpoint"

# Contact form — Formspree (optional)
# Sign up at https://formspree.io, create a form, and paste the form ID here (e.g. xpwzabcd)
NEXT_PUBLIC_FORMSPREE_ID="your-formspree-form-id"

# Unsplash — stock photos
# Register your app at https://unsplash.com/developers → "New Application"
# Demo limit: 50 req/hr | Production (after approval): 5,000 req/hr
UNSPLASH_ACCESS_KEY="your_unsplash_access_key"
# UNSPLASH_SECRET_KEY is server-side only — never expose to the browser
UNSPLASH_SECRET_KEY="your_unsplash_secret_key"

# Giscus comments (optional)
# Get these values from https://giscus.app after enabling GitHub Discussions
NEXT_PUBLIC_GISCUS_REPO="owner/repo"
NEXT_PUBLIC_GISCUS_REPO_ID="R_kgDO..."
NEXT_PUBLIC_GISCUS_CATEGORY="General"
NEXT_PUBLIC_GISCUS_CATEGORY_ID="DIC_kwDO..."
