{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "check:env": "node scripts/check-env.js",
    "diagnostics": "bash scripts/diagnostics.sh",
    "build": "npm run check:env && next build",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:regression": "vitest run tests/regression",
    "test:bdd": "vitest run tests/features",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run && npm run lint",
    "ci": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@heroicons/react": "^2.2.0",
    "@vercel/analytics": "^1.6.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/html-formatter": "^23.0.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "aria-query": "^5.3.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tinyglobby": "^0.2.15",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "1.31.1",
    "lightningcss-darwin-x64": "1.31.1"
  }
}
